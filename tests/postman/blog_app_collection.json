          ]}}]
        },
        {
          "name": "GET /posts/create — Форма створення (200 для авторизованого)",
          "request": { "method": "GET", "url": "{{base_url}}/posts/create" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Статус 200', () => pm.response.to.have.status(200));",
            "pm.test('Форма створення поста присутня', () => {",
            "    const body = pm.response.text();",
            "    pm.expect(body).to.include('Add a Blog/Post');",
            "    pm.expect(body).to.include('id=\"title\"');",
            "});",
            "const m = pm.response.text().match(/name=\"csrf_token\"[^>]*value=\"([^\"]+)\"/);",
            "if (m) pm.collectionVariables.set('csrf_token', m[1]);"
          ]}}]
        },
        {
          "name": "POST /posts/create — Успішне створення поста (200)",
          "request": {
            "method": "POST", "url": "{{base_url}}/posts/create",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "csrf_token",   "value": "{{csrf_token}}" },
              { "key": "title",        "value": "Postman Test Post" },
