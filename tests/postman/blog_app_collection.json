                  "});",
                  "",
                  "const match = pm.response.text().match(/name=\"csrf_token\"[^>]*value=\"([^\"]+)\"/);",
                  "if (match) { pm.collectionVariables.set('csrf_token', match[1]); }"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login — Успішний вхід (200)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "csrf_token", "value": "{{csrf_token}}" },
                { "key": "username",   "value": "{{test_username}}" },
                { "key": "password",   "value": "{{test_password}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Статус 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Вітальне повідомлення присутнє', () => {",
                  "    pm.expect(pm.response.text()).to.include('postman_user');",
                  "});",
                  "pm.test('Кнопка Logout присутня (авторизований)', () => {",
                  "    pm.expect(pm.response.text()).to.include('id=\"log_out\"');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auth/login — CSRF для неправильного паролю",
          "request": { "method": "GET", "url": "{{base_url}}/auth/login" },
          "event": [{ "listen": "test", "script": { "exec": [
            "const m = pm.response.text().match(/name=\"csrf_token\"[^>]*value=\"([^\"]+)\"/);",
            "if (m) pm.collectionVariables.set('csrf_token', m[1]);"
          ]}}]
        },
        {
          "name": "POST /auth/login — Невірний пароль (200 з помилкою)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "csrf_token", "value": "{{csrf_token}}" },
                { "key": "username",   "value": "{{test_username}}" },
                { "key": "password",   "value": "WrongPassword!" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Статус 200', () => pm.response.to.have.status(200));",
            "pm.test('Повідомлення про помилку присутнє', () => {",
            "    pm.expect(pm.response.text()).to.include('alert_error');",
            "});",
            "pm.test('Залишаємось на сторінці входу', () => {",
            "    pm.expect(pm.response.text()).to.include('Sign In');",
            "});"
          ]}}]
        },
        {
          "name": "GET /auth/logout — Вихід (redirect → 200)",
          "request": { "method": "GET", "url": "{{base_url}}/auth/logout" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Статус 200 після редиректу', () => pm.response.to.have.status(200));",
            "pm.test('Повідомлення про вихід присутнє', () => {",
            "    pm.expect(pm.response.text()).to.include('alert');",
            "});"
          ]}}]
        }
      ]
    },

    {
      "name": "4. Auth — Скидання паролю",
      "item": [
        {
