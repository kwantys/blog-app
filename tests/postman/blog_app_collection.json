          "request": { "method": "GET", "url": "{{base_url}}/auth/logout" },
          "event": [{ "listen": "pre-request", "script": { "exec": [
            "// Очищаємо cookies щоб симулювати неавторизованого",
            "pm.cookies.clear('localhost');"
          ]}},
          { "listen": "test", "script": { "exec": [
            "pm.test('Редирект на сторінку входу', () => {",
            "    pm.expect(pm.response.text()).to.include('Sign In');",
            "});"
          ]}}]
        },
        {
          "name": "GET /users/settings/profile — Без авторизації (redirect 200)",
          "request": { "method": "GET", "url": "{{base_url}}/users/settings/profile" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Редирект на login для неавторизованого', () => {",
            "    pm.expect(pm.response.text()).to.include('Sign In');",
            "});"
          ]}}]
        }
      ]
    }
  ]
}
