          "name": "GET /posts/1 — Деталь поста (200 або 404)",
          "request": { "method": "GET", "url": "{{base_url}}/posts/{{post_id}}" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Статус 200 або 404', () => {",
            "    pm.expect([200, 404]).to.include(pm.response.code);",
            "});",
            "if (pm.response.code === 200) {",
            "    pm.test('Деталь поста відкрилась', () => {",
            "        pm.expect(pm.response.text()).to.include('comments');",
            "    });",
            "    const m = pm.response.text().match(/name=\"csrf_token\"[^>]*value=\"([^\"]+)\"/);",
            "    if (m) pm.collectionVariables.set('csrf_token', m[1]);",
            "}"
          ]}}]
        },
