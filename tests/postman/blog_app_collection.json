{
  "info": {
    "name": "Blog App — API Tests",
    "description": "Повне тестування всіх endpoints Flask Blog App.\nЗапуск: newman run blog_app_collection.json -e blog_app_environment.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000" },
    { "key": "session_cookie", "value": "" },
    { "key": "csrf_token", "value": "" },
    { "key": "test_username", "value": "postman_user" },
    { "key": "test_email", "value": "postman@example.com" },
    { "key": "test_password", "value": "Password1!" },
    { "key": "post_id", "value": "1" }
  ],
  "item": [

    {
      "name": "1. Health Check",
      "item": [
        {
          "name": "GET / — Головна сторінка (200)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/",
            "description": "Перевірка що головна сторінка відповідає зі статусом 200"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Статус 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Відповідь містить Blog App', () => {",
                  "    pm.expect(pm.response.text()).to.include('Blog App');",
                  "});",
                  "pm.test('Content-Type є text/html', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/html');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /login — Аліас входу (redirect)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/login",
            "description": "Аліас /login має редиректити на /auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Статус 200 після редиректу', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Відповідь містить Sign In', () => {",
                  "    pm.expect(pm.response.text()).to.include('Sign In');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /register — Аліас реєстрації (redirect)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Статус 200 після редиректу', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Відповідь містить Sign Up', () => {",
                  "    pm.expect(pm.response.text()).to.include('Sign Up');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "2. Auth — Реєстрація",
      "item": [
        {
          "name": "GET /auth/register — Форма реєстрації (200)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Статус 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Форма реєстрації присутня', () => {",
                  "    const body = pm.response.text();",
                  "    pm.expect(body).to.include('Sign Up');",
                  "    pm.expect(body).to.include('id=\"username\"');",
                  "    pm.expect(body).to.include('id=\"email\"');",
                  "    pm.expect(body).to.include('id=\"password\"');",
                  "});",
                  "",
                  "// Витягуємо CSRF token для наступного запиту",
                  "const body = pm.response.text();",
                  "const match = body.match(/name=\"csrf_token\"[^>]*value=\"([^\"]+)\"/);",
                  "if (match) {",
                  "    pm.collectionVariables.set('csrf_token', match[1]);",
                  "    console.log('CSRF token збережено:', match[1].substring(0,20) + '...');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/register — Успішна реєстрація (302)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" },
              { "key": "Referer", "value": "{{base_url}}/auth/register" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "csrf_token", "value": "{{csrf_token}}" },
                { "key": "username",   "value": "{{test_username}}" },
                { "key": "email",      "value": "{{test_email}}" },
                { "key": "password",   "value": "{{test_password}}" },
                { "key": "password2",  "value": "{{test_password}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Статус 200 (після редиректу на головну)', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Повідомлення Congrats присутнє', () => {",
                  "    pm.expect(pm.response.text()).to.include('Congrats');",
                  "});",
                  "",
                  "// Зберігаємо session cookie",
                  "const cookie = pm.cookies.get('session');",
                  "if (cookie) {",
                  "    pm.collectionVariables.set('session_cookie', cookie);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auth/register — Отримати CSRF (для дубля)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.text();",
                  "const match = body.match(/name=\"csrf_token\"[^>]*value=\"([^\"]+)\"/);",
                  "if (match) { pm.collectionVariables.set('csrf_token', match[1]); }"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/register — Дублікат email (залишається на /register)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "csrf_token", "value": "{{csrf_token}}" },
                { "key": "username",   "value": "another_postman_user" },
                { "key": "email",      "value": "{{test_email}}" },
                { "key": "password",   "value": "{{test_password}}" },
                { "key": "password2",  "value": "{{test_password}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Статус 200 (форма з помилкою)', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Залишаємось на сторінці реєстрації', () => {",
                  "    pm.expect(pm.response.text()).to.include('Sign Up');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

    {
      "name": "3. Auth — Вхід та Вихід",
      "item": [
        {
          "name": "GET /auth/login — Форма входу (200)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
