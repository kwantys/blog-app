{
  "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
  "version": "2.0",
  "name": "Blog App — Record & Play Tests",
  "url": "http://localhost:5000",
  "tests": [
    {
      "id": "test-01-register-success",
      "name": "TC-01: Успішна реєстрація нового користувача",
      "commands": [
        {
          "id": "cmd-01-01",
          "comment": "Відкрити сторінку реєстрації",
          "command": "open",
          "target": "/register",
          "value": ""
        },
        {
          "id": "cmd-01-02",
          "comment": "Перевірити заголовок сторінки",
          "command": "assertText",
          "target": "css=.panel-heading",
          "value": "Sign Up"
        },
        {
          "id": "cmd-01-03",
          "comment": "Ввести імʼя користувача",
          "command": "type",
          "target": "id=username",
          "value": "testuser_selenium"
        },
        {
          "id": "cmd-01-04",
          "comment": "Ввести email",
          "command": "type",
          "target": "id=email",
          "value": "selenium@example.com"
        },
        {
          "id": "cmd-01-05",
          "comment": "Ввести пароль",
          "command": "type",
          "target": "id=password",
          "value": "Password1!"
        },
        {
          "id": "cmd-01-06",
          "comment": "Підтвердити пароль",
          "command": "type",
          "target": "id=confirm",
          "value": "Password1!"
        },
        {
          "id": "cmd-01-07",
          "comment": "Натиснути кнопку реєстрації",
          "command": "click",
          "target": "id=register",
          "value": ""
        },
        {
          "id": "cmd-01-08",
          "comment": "Перевірити повідомлення про успіх",
          "command": "assertElementPresent",
          "target": "id=alert_success",
          "value": ""
        },
        {
          "id": "cmd-01-09",
          "comment": "Перевірити текст повідомлення",
          "command": "assertTextPresent",
          "target": "",
          "value": "Congrats"
        },
        {
          "id": "cmd-01-10",
          "comment": "Перевірити редирект на головну",
          "command": "assertLocation",
          "target": "http://localhost:5000/",
          "value": ""
        }
      ]
    },
